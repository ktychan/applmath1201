% vim: ft=tex

\input{./tikz.tex.preamble}
\input{./typography.tex.preamble}
\setbeamersize{text margin left=.5cm} 
\setbeamersize{text margin right=.5cm} 

\usepackage{enumitem}
\usepackage{qrcode}
\usepackage{multicol}


\usetheme{metropolis}
\setbeamercolor{normal text}{fg=WesternDeepFocus}
\setbeamercolor{palette primary}{bg=WesternPurple, fg=WesternWhite}
\setbeamercolor{frametitle}{bg=WesternPurple, fg=WesternWhite}
\setbeamercolor{structure}{fg=WesternPurple}
\setbeamercolor{progress bar}{fg=WesternOrchid}
\setbeamercolor{background canvas}{bg=white}

\metroset{
  progressbar=frametitle, % nice modern look
  numbering=none,
}

%
% geometry
%
\setbeamersize{text margin left=.5cm} 
\setbeamersize{text margin right=.5cm} 
\setbeamertemplate{items}[default]
\setlist{itemsep={0.5ex}}
\setlist[itemize]{
  label={\(\bullet\)}
}
\setlist[enumerate]{
  label={(\arabic*)}
}

% 
% background
%
\setbeamercovered{dynamic}
\setbeamertemplate{background canvas}{
  \begin{tikzpicture}[remember picture,overlay]
    \node[
      anchor=south east,
      xshift=-0.5em,
      yshift=0.5em
    ] at (current page.south east) {
      \includegraphics[height=3ex]{./standalones/WesternU_Stacked_CMYK.eps}
    };
  \end{tikzpicture}
}

\newenvironment{poll}{
  \begingroup
  \setbeamertemplate{background canvas}{
    \begin{tikzpicture}[overlay, remember picture]
      \node[main!10, anchor=south] at (current page.south) {\resizebox{\textwidth}{!}{iClicker}};
    \end{tikzpicture}    
  }
  \begin{frame}
}{
  \end{frame}
  \endgroup
}


\newenvironment{iclicker}{
  \begingroup
  \setbeamertemplate{background canvas}{
    \begin{tikzpicture}[overlay, remember picture]
      \node[main!10, anchor=south] at (current page.south) {\resizebox{\textwidth}{!}{iClicker}};
    \end{tikzpicture}    
  }
  \begin{frame}
}{
  \end{frame}
  \endgroup
}
